rules_version = '2';

// Reference ruleset for portfolio-df758 — REVIEW against your console rules
// before deploying (firebase deploy --only firestore:rules) or paste manually.
// New in this version: `stats` (public visit counters) and `sessions`.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Public portfolio data — read by the website without auth
    match /profiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);

      // Signed-in device history — strictly private to the owner
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // Username reservations — readable by anyone (availability checks on the
    // signup form run before authentication)
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // Visit counters — written ONLY by the server (/api/visit via Admin SDK,
    // which bypasses these rules). Clients can never write, owner reads.
    match /stats/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
  }
}
